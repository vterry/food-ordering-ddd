@startuml Saga-Cancel-Sequence
!theme plain
skinparam sequenceMessageAlign center
skinparam sequenceArrowThickness 2
skinparam sequenceParticipant underline

participant "Cliente" as Cliente
participant "Ordering" as Ordering
participant "Payment" as Payment
participant "Restaurant" as Restaurant
participant "Delivery" as Delivery

== Cancelamento por Cliente (antes de restaurante) ==
Cliente -> Ordering: POST /orders/{id}/cancel
activate Ordering
Ordering -> Ordering: order.Cancel("CUSTOMER_REQUEST")
alt order.PAID
  Ordering -> Payment: RefundPayment (comando)
  activate Payment
  Payment -> Payment: Refund()
  Payment -> Payment: PaymentRefunded [outbox]
  Payment -> Ordering: PaymentRefunded
  deactivate Payment
end
Ordering -> Ordering: OrderCancelled [outbox]
Ordering -> Cliente: 200 OK
deactivate Ordering

== Restaurante rejeita (compensação) ==
note over Restaurant: Operador rejeita
Restaurant -> Ordering: RestaurantOrderRejected
activate Ordering
Ordering -> Ordering: Cancel("RESTAURANT_REJECTED")
Ordering -> Payment: RefundPayment
Payment -> Payment: Refund()
Ordering -> Ordering: OrderCancelled [outbox]
deactivate Ordering

== Delivery falha (compensação parcial) ==
note over Delivery: Endereço errado
Delivery -> Ordering: DeliveryStatusChanged(FAILED)
activate Ordering
Ordering -> Ordering: MarkFailed("DELIVERY_FAILED")
Ordering -> Payment: RefundPayment(partial=70%)
Payment -> Payment: PartialRefund(70%)
Ordering -> Ordering: OrderFailed [outbox]
deactivate Ordering

@enduml
