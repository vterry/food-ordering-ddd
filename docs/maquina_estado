@startuml Order-State-Machine
!theme plain
skinparam state {
  BackgroundColor<<normal>> LightBlue
  BackgroundColor<<error>> LightCoral
  BorderColor Black
  FontSize 12
}
skinparam stateFontSize 11

[*] --> PENDING : PlaceOrder
PENDING --> PAID : PaymentAuthorized
PENDING --> CANCELLED : PaymentFailed\nCustomerCancel
PAID --> CONFIRMED : RestaurantOrderAccepted
PAID --> CANCELLED : RestaurantOrderRejected\nTimeout (30min)
CONFIRMED --> IN_DELIVERY : DeliveryOnRoute
CONFIRMED --> CANCELLED : CustomerCancel\n(pre-delivery)
IN_DELIVERY --> DELIVERED : DeliveryDelivered
IN_DELIVERY --> FAILED : DeliveryFailed
DELIVERED --> [*] : Concluído
CANCELLED --> [*] : Saga abortada
FAILED --> [*] : Suporte manual

state PENDING <<normal>>
state PAID <<normal>>
state CONFIRMED <<normal>>
state IN_DELIVERY <<normal>>
state DELIVERED <<normal>>
state CANCELLED <<error>>
state FAILED <<error>>

note right of CANCELLED
  Motivos:
  - PaymentFailed
  - RestaurantRejected
  - CustomerCancel
  - Timeout
end note

note right of FAILED
  Motivos:
  - DeliveryFailed
  - Erro irrecuperável
  - Suporte manual
end note

@enduml
